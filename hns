import pandas as pd
from config import *

def analyze_results():
    # Load matched data and categorical columns
    matched_data = pd.read_parquet('matched_data.parquet')
    categorical_cols = pd.read_csv('categorical_cols.csv')['0'].tolist()
    
    # Calculate ATE
    ate = matched_data[matched_data[TREATMENT_VAR] == 1][OUTCOME_VAR].mean() - \
          matched_data[matched_data[TREATMENT_VAR] == 0][OUTCOME_VAR].mean()
    
    print(f"\nResults:")
    print(f"Average Treatment Effect: {ate:.4f}")
    
    # Analyze distribution of categorical variables
    for col in categorical_cols:
        col_dummies = [c for c in matched_data.columns if c.startswith(col+'_')]
        for dummy in col_dummies:
            print(f"\nDistribution for {dummy}:")
            print(matched_data.groupby([TREATMENT_VAR, dummy]).size())
