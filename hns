 Prepare data for HNSW matching
with Timer("Preparing data for HNSW matching"):
    # Include both propensity score and covariates in matching
    matching_vars = features_for_model + ['pscore']
    
    # Normalize variables for distance calculation
    scaler = StandardScaler()
    
    # Scale treatment group
    treated_data = treatment_df[matching_vars].copy()
    treated_scaled = scaler.fit_transform(treated_data)
    
    # Scale control group using same scaler
    control_data = control_df[matching_vars].copy()
    control_scaled = scaler.transform(control_data)
    
    # Convert to float32 for HNSW
    treated_scaled = treated_scaled.astype('float32')
    control_scaled = control_scaled.astype('float32')
    
    print("\nMatching dimensions:", len(matching_vars))

# Initialize HNSW
with Timer("HNSW initialization"):
    dimension = len(matching_vars)
    m = 32  # Increased connections per layer for better accuracy
    ef_construction = 80  # Increased for better index quality
    
    index = faiss.IndexHNSWFlat(dimension, m)
    index.hnsw.efConstruction = ef_construction
    index.add(control_scaled)
    
    ef_search = 20  # Increased for more thorough search
    index.hnsw.efSearch = ef_search
    
    k = min(50, len(control_df))  # Increased k to have more candidates
    distances, indices = index.search(treated_scaled, k)

# Perform matching with quality checks
with Timer(f"Matching process for {len(treatment_df)} treated units"):
    matched_pairs = []
    used_control_indices = set()
    unmatched_treated = 0
    
    # Calculate distance threshold based on mahalanobis distance
    distance_threshold = chi2.ppf(0.95, df=dimension)
    
    for i, (dist, idx) in enumerate(zip(distances, indices)):
        matched_controls = []
        
        # Sort potential matches by distance
        potential_matches = [(d, control_idx) for d, control_idx in zip(dist, idx) 
                           if control_idx != -1 and control_idx not in used_control_indices]
        potential_matches.sort(key=lambda x: x[0])
        
        for distance, control_idx in potential_matches:
            if len(matched_controls) >= MATCHING_RATIO:
                break
                
            # Check if distance is within threshold
            if distance <= distance_threshold:
                matched_controls.append(control_idx)
                used_control_indices.add(control_idx)
        
        if len(matched_controls) == MATCHING_RATIO:
            matched_pairs.append(treatment_df.iloc[i])
            for control_idx in matched_controls:
                matched_pairs.append(control_df.iloc[control_idx])
        else:
            unmatched_treated += 1
    
    matched_df = pd.DataFrame(matched_pairs)
    
    print(f"\nMatching Statistics:")
    print(f"Successfully matched treated units: {len(matched_pairs) // (MATCHING_RATIO + 1)}")
    print(f"Unmatched treated units: {unmatched_treated}")
    print(f"Total matched control units: {len(matched_pairs) - (len(matched_pairs) // (MATCHING_RATIO + 1))}")

# Check matching quality
print("\nMatching Quality Assessment:")
for var in matching_vars:
    treated_mean = matched_df[matched_df[TREATMENT_VAR] == 1][var].mean()
    treated_std = matched_df[matched_df[TREATMENT_VAR] == 1][var].std()
    control_mean = matched_df[matched_df[TREATMENT_VAR] == 0][var].mean()
    control_std = matched_df[matched_df[TREATMENT_VAR] == 0][var].std()
    
    std_diff = (treated_mean - control_mean) / np.sqrt((treated_std**2 + control_std**2) / 2)
    
    print(f"\n{var}:")
    print(f"Treated: Mean = {treated_mean:.4f}, Std = {treated_std:.4f}")
    print(f"Control: Mean = {control_mean:.4f}, Std = {control_std:.4f}")
    print(f"Standardized Difference: {std_diff:.4f}")
