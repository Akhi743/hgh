import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.linear_model import LogisticRegression
import faiss
import warnings
warnings.filterwarnings('ignore')

# Define inputs
DATA_PATH = "marketing_test_case.csv"
X_VARIABLES = ["age", "gender_cd", "social_risk_score", "hpd_hyp", "hpd_hyc", "hpd_ast", "hpd_dia"]
TREATMENT_VAR = "grp_binary"
OUTCOME_VAR = "social_risk_score"
MATCHING_RATIO = 2
N_NEIGHBORS = 5
CALIPER_SD = 0.25

# 1. First let's load and examine the data
print("Step 1: Data Examination")
print("======================")
df = pd.read_csv(DATA_PATH)
print(f"\nTotal observations: {len(df)}")

# Examine each variable
print("\nVariable Analysis:")
print("-----------------")
for var in X_VARIABLES:
    n_unique = df[var].nunique()
    n_missing = df[var].isnull().sum()
    print(f"\n{var}:")
    print(f"Data type: {df[var].dtype}")
    print(f"Unique values: {n_unique}")
    print(f"Missing values: {n_missing}")
    print("Sample values:", df[var].head().tolist())

# Identify categorical variables
categorical_vars = []
numeric_vars = []

for var in X_VARIABLES:
    # Check if variable is already numeric
    if df[var].dtype in ['int64', 'float64']:
        if df[var].nunique() < 10:  # If few unique values, treat as categorical
            categorical_vars.append(var)
        else:
            numeric_vars.append(var)
    else:
        categorical_vars.append(var)

print("\nVariable Classification:")
print("----------------------")
print("Categorical variables:", categorical_vars)
print("Numeric variables:", numeric_vars)

# Treatment variable distribution
print("\nTreatment Distribution:")
print("---------------------")
print(df[TREATMENT_VAR].value_counts(normalize=True))

# 2. Prepare data with one-hot encoding
print("\nStep 2: Data Preparation")
print("======================")

# One-hot encode categorical variables
df_encoded = pd.get_dummies(df, columns=categorical_vars, prefix_sep='_')

# Get list of feature columns after encoding
feature_columns = []
for var in numeric_vars:
    feature_columns.append(var)
for var in categorical_vars:
    feature_columns.extend([col for col in df_encoded.columns if col.startswith(f"{var}_")])

print("\nFeatures after encoding:")
print("----------------------")
print("Total features:", len(feature_columns))
print("Feature names:", feature_columns)

# 3. Calculate propensity scores
print("\nStep 3: Propensity Score Calculation")
print("=================================")

# Standardize features
scaler = StandardScaler()
X = scaler.fit_transform(df_encoded[feature_columns])

# Fit logistic regression
lr = LogisticRegression(random_state=42)
lr.fit(X, df_encoded[TREATMENT_VAR])

# Calculate propensity scores
propensity_scores = lr.predict_proba(X)[:, 1]

# Analyze coefficients
coefficients = pd.DataFrame({
    'feature': feature_columns,
    'coefficient': lr.coef_[0],
    'abs_coefficient': abs(lr.coef_[0])
})
coefficients = coefficients.sort_values('abs_coefficient', ascending=False)

print("\nPropensity Score Model:")
print("---------------------")
print("Top influential features:")
print(coefficients.head())

print("\nPropensity Score Distribution:")
print("----------------------------")
print(pd.Series(propensity_scores).describe())

# 4. Perform matching
print("\nStep 4: Matching Process")
print("=====================")

# Split into treated and control groups
treated_mask = df_encoded[TREATMENT_VAR] == 1
control_mask = ~treated_mask

treated_indices = np.where(treated_mask)[0]
control_indices = np.where(control_mask)[0]

print("\nMatching Process:")
print("----------------")
print(f"Treated units: {len(treated_indices)}")
print(f"Control units: {len(control_indices)}")

# Prepare propensity scores for matching
treated_ps = propensity_scores[treated_mask].reshape(-1, 1).astype('float32')
control_ps = propensity_scores[control_mask].reshape(-1, 1).astype('float32')

# Initialize FAISS index
index = faiss.IndexHNSWFlat(1, N_NEIGHBORS)
index.add(control_ps)

# Calculate caliper
caliper = CALIPER_SD * propensity_scores.std()
print(f"Caliper width: {caliper:.4f}")

# Perform matching
distances, indices = index.search(treated_ps, MATCHING_RATIO)

# Create matches dataframe
matches = []
for i, treated_idx in enumerate(treated_indices):
    for j in range(MATCHING_RATIO):
        if j < len(indices[i]):
            control_idx = control_indices[indices[i][j]]
            distance = distances[i][j]
            ps_diff = abs(propensity_scores[treated_idx] - propensity_scores[control_idx])
            
            if ps_diff <= caliper:
                matches.append({
                    'treated_index': treated_idx,
                    'control_index': control_idx,
                    'ps_diff': ps_diff,
                    'distance': distance
                })

matches_df = pd.DataFrame(matches)

print("\nMatching Results:")
print("----------------")
print(f"Matched pairs found: {len(matches_df)}")
if len(matches_df) > 0:
    print(f"Average PS difference: {matches_df['ps_diff'].mean():.4f}")

# 5. Create and save final matched dataset
matched_indices = pd.concat([
    pd.Series(matches_df['treated_index'].values),
    pd.Series(matches_df['control_index'].values)
])

matched_data = df_encoded.iloc[matched_indices].copy()
matched_data['matched_set'] = np.repeat(range(len(matches_df)), 2)
matched_data['is_treated'] = np.tile([1, 0], len(matches_df))

# Save results
matched_data.to_csv('matched_dataset.csv', index=False)
coefficients.to_csv('propensity_score_coefficients.csv', index=False)
matches_df.to_csv('matching_pairs.csv', index=False)

print("\nResults saved to:")
print("- matched_dataset.csv")
print("- propensity_score_coefficients.csv")
print("- matching_pairs.csv")

# Print final matching statistics
print("\nFinal Matching Statistics:")
print("------------------------")
print(f"Total matched pairs: {len(matches_df)}")
print(f"Unique treated units matched: {len(matches_df['treated_index'].unique())}")
print(f"Unique control units matched: {len(matches_df['control_index'].unique())}")
print(f"Average propensity score difference: {matches_df['ps_diff'].mean():.4f}")
