import pandas as pd
import numpy as np
from sklearn.linear_model import LogisticRegression
import faiss
import time
import warnings
warnings.filterwarnings('ignore')

# Config
DATA_PATH = "HCA_unmatched_data_setup.parquet"
X_VARIABLES = ["age", "gender_cd", "medical_coverage_tier"]
TREATMENT_VAR = "grp_binary"
OUTCOME_VAR = "social_risk_score"
MATCHING_RATIO = 2
N_NEIGHBORS = 5
CALIPER_SD = 0.25

class Timer:
    def __init__(self, description):
        self.description = description
    
    def __enter__(self):
        self.start = time.time()
        return self
    
    def __exit__(self, *args):
        self.end = time.time()
        self.duration = self.end - self.start
        print(f"{self.description}: {self.duration:.4f} seconds")

# Step 1: Data Preparation
print(f"\nLoading data from {DATA_PATH}...")
df = pd.read_parquet(DATA_PATH)

# Handle missing values
df_clean = df.copy()
for col in X_VARIABLES:
    if df_clean[col].dtype in ['int64', 'float64']:
        df_clean[col] = df_clean[col].fillna(df_clean[col].median())
    else:
        df_clean[col] = df_clean[col].fillna(df_clean[col].mode()[0])

# Create dummy variables
with Timer("Creating dummy variables"):
    df_encoded = df_clean.copy()
    categorical_cols = []
    
    for col in X_VARIABLES:
        if col in df_encoded.columns:
            print(f"\nColumn {col} dtype:", df_encoded[col].dtype)
            print(f"Column {col} unique values:", df_encoded[col].unique())
            
            if df_encoded[col].nunique() == 2 and df_encoded[col].dtype in ['int64', 'float64']:
                df_encoded[col] = df_encoded[col].map({0: 'A', 1: 'B'})
            
            if df_encoded[col].dtype == 'object' or df_encoded[col].nunique() < 10:
                categorical_cols.append(col)
                unique_vals = df_encoded[col].dropna().unique()
                
                for val in unique_vals:
                    col_name = f"{col}_{val}"
                    df_encoded[col_name] = (df_encoded[col] == val).astype(int)
                
                df_encoded = df_encoded.drop(columns=[col])
                
            print(f"Created columns for {col}:", [c for c in df_encoded.columns if c.startswith(f"{col}_")])

features_for_model = [col for col in X_VARIABLES if col not in categorical_cols]
for col in categorical_cols:
    dummy_cols = [c for c in df_encoded.columns if c.startswith(col + '_')]
    features_for_model.extend(dummy_cols)

# Handle remaining missing values
nan_check = df_encoded[features_for_model].isna().sum()
if nan_check.any():
    print("NaN values found in features:")
    print(nan_check[nan_check > 0])
    df_encoded = df_encoded.dropna(subset=features_for_model)

if df_encoded[TREATMENT_VAR].isna().any():
    print("NaN values found in treatment variable")
    df_encoded = df_encoded.dropna(subset=[TREATMENT_VAR])

if df_encoded[OUTCOME_VAR].isna().any():
    print("NaN values found in outcome variable")
    df_encoded = df_encoded.dropna(subset=[OUTCOME_VAR])

# Step 2: Propensity Score Calculation
with Timer("Calculating propensity scores"):
    model = LogisticRegression(
        penalty='l2',
        C=1e6,
        solver='lbfgs',
        random_state=42,
        max_iter=1000
    )
    model.fit(df_encoded[features_for_model], df_encoded[TREATMENT_VAR])
    ps = model.predict_proba(df_encoded[features_for_model])[:, 1]
    
    print("\nPropensity Score Model Coefficients:")
    coef_df = pd.DataFrame({
        'Feature': features_for_model,
        'Coefficient': model.coef_[0]})
    print(coef_df.to_string(index=False))

df_encoded['pscore'] = ps

# Step 3: Matching
caliper = np.std(df_encoded['pscore']) * CALIPER_SD

treatment_df = df_encoded[df_encoded[TREATMENT_VAR] == 1].copy()
control_df = df_encoded[df_encoded[TREATMENT_VAR] == 0].copy()

with Timer("HNSW initialization"):
    treated_pscores = treatment_df['pscore'].values.reshape(-1, 1).astype('float32')
    control_pscores = control_df['pscore'].values.reshape(-1, 1).astype('float32')
    
    dimension = 1
    m = 16
    ef_construction = 40
    
    index = faiss.IndexHNSWFlat(dimension, m)
    index.hnsw.efConstruction = ef_construction
    index.add(control_pscores)
    
    ef_search = 10
    index.hnsw.efSearch = ef_search
    
    k = min(N_NEIGHBORS, len(control_df))
    distances, indices = index.search(treated_pscores, k)

with Timer(f"Matching process for {len(treatment_df)} treated units"):
    matched_pairs = []
    used_control_indices = set()
    unmatched_treated = 0
    
    for i, (dist, idx) in enumerate(zip(distances, indices)):
        matched_controls = []
        treated_pscore = treated_pscores[i][0]
        
        for d, control_idx in zip(dist, idx):
            if len(matched_controls) >= MATCHING_RATIO:
                break
            
            if control_idx == -1:
                continue
            
            control_pscore = control_pscores[control_idx][0]
            ps_diff = abs(treated_pscore - control_pscore)
            
            if ps_diff <= caliper and control_idx not in used_control_indices:
                matched_controls.append(control_idx)
                used_control_indices.add(control_idx)
        
        if len(matched_controls) == MATCHING_RATIO:
            matched_pairs.append(treatment_df.iloc[i])
            for control_idx in matched_controls:
                matched_pairs.append(control_df.iloc[control_idx])
        else:
            unmatched_treated += 1
    
    print(f"\nMatching Statistics:")
    print(f"Successfully matched treated units: {len(matched_pairs) // (MATCHING_RATIO + 1)}")
    print(f"Unmatched treated units: {unmatched_treated}")
    print(f"Total matched control units: {len(matched_pairs) - (len(matched_pairs) // (MATCHING_RATIO + 1))}")

matched_df = pd.DataFrame(matched_pairs)

# Step 4: Analysis
ate = matched_df[matched_df[TREATMENT_VAR] == 1][OUTCOME_VAR].mean() - \
      matched_df[matched_df[TREATMENT_VAR] == 0][OUTCOME_VAR].mean()

print(f"\nResults:")
print(f"Average Treatment Effect: {ate:.4f}")

for col in categorical_cols:
    col_dummies = [c for c in matched_df.columns if c.startswith(col+'_')]
    for dummy in col_dummies:
        print(f"\nDistribution for {dummy}:")
        print(matched_df.groupby([TREATMENT_VAR, dummy]).size())
