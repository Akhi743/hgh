    """Enhanced matching using reverse priority order"""
    matched_pairs = []
    used_control_indices = set()
    unmatched_treated = 0
    
    # Get indices of treated units that are hardest to match (highest PS)
    treated_indices = np.argsort(-treatment_df['pscore'].values)
    
    for treated_idx in treated_indices:
        dist = distances[treated_idx]
        idx = indices[treated_idx]
        matched_controls = []
        treated_pscore = treatment_df['pscore'].iloc[treated_idx]
        
        # Get all valid controls first
        valid_controls = []
        for d, control_idx in zip(dist, idx):
            if control_idx == -1:
                continue
                
            control_pscore = control_df['pscore'].iloc[control_idx]
            ps_diff = abs(treated_pscore - control_pscore)
            
            if ps_diff <= caliper and control_idx not in used_control_indices:
                valid_controls.append((control_pscore, control_idx))
        
        # Sort by propensity score
        valid_controls.sort(key=lambda x: abs(x[0] - treated_pscore))
        
        # Take matches ensuring even distribution
        for _, control_idx in valid_controls[:MATCHING_RATIO]:
            if control_idx not in used_control_indices:
                matched_controls.append(control_idx)
        
        if len(matched_controls) == MATCHING_RATIO:
            matched_pairs.append(treatment_df.iloc[treated_idx])
            for control_idx in matched_controls:
                matched_pairs.append(control_df.iloc[control_idx])
                used_control_indices.add(control_idx)
        else:
            unmatched_treated += 1
    
    return matched_pairs, unmatched_treated











def find_matches(distances, indices, treatment_df, control_df, caliper):
    """Enhanced matching strategy to ensure all treated units get matched"""
    matched_pairs = []
    used_control_indices = set()
    
    # First sort controls by number of potential matches (ascending)
    treated_availability = []
    for treated_idx in range(len(treatment_df)):
        treated_pscore = treatment_df['pscore'].iloc[treated_idx]
        available_matches = sum(1 for control_idx in indices[treated_idx] 
                              if control_idx != -1 and 
                              abs(treated_pscore - control_df['pscore'].iloc[control_idx]) <= caliper)
        treated_availability.append((available_matches, treated_idx))
    
    treated_availability.sort()  # Process hardest-to-match first
    
    # Process each treated unit
    for _, treated_idx in treated_availability:
        dist = distances[treated_idx]
        idx = indices[treated_idx]
        matched_controls = []
        treated_pscore = treatment_df['pscore'].iloc[treated_idx]
        
        available_controls = []
        for control_idx in idx:
            if control_idx == -1:
                continue
            
            if control_idx in used_control_indices:
                continue
                
            control_pscore = control_df['pscore'].iloc[control_idx]
            ps_diff = abs(treated_pscore - control_pscore)
            
            if ps_diff <= caliper:
                available_controls.append((ps_diff, control_idx))
        
        # Sort by PS difference
        available_controls.sort()
        
        # Take best available matches
        for _, control_idx in available_controls[:MATCHING_RATIO]:
            matched_controls.append(control_idx)
            used_control_indices.add(control_idx)
            
        # Always add treated unit and its matches
        if matched_controls:
            matched_pairs.append(treatment_df.iloc[treated_idx])
            for control_idx in matched_controls:
                matched_pairs.append(control_df.iloc[control_idx])
    
    return matched_pairs, 0
