# Compare covariates distribution
def compare_groups(df, treatment_col, covariates):
    from scipy import stats
    
    results = []
    for cov in covariates:
        treated = df[df[treatment_col]==1][cov]
        control = df[df[treatment_col]==0][cov]
        
        # T-test for continuous variables
        t_stat, p_val = stats.ttest_ind(treated, control)
        
        # Standardized difference
        std_diff = (treated.mean() - control.mean()) / \
                  np.sqrt((treated.var() + control.var()) / 2)
                  
        results.append({
            'covariate': cov,
            'p_value': p_val,
            'std_diff': std_diff
        })
    
    return pd.DataFrame(results)

