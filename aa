class DataLoader:
    def load_train_test_lalonde_random(self, csv_path, split_size=0.8):
        np_covariates_X, np_treatment_T, np_outcomes_Y_f, np_outcomes_Y_cf, no = \
            self.preprocess_dataset_for_training(csv_path)
            
        print("ps_np_covariates_X: {0}".format(np_covariates_X.shape))
        print("ps_np_treatment_Y: {0}".format(np_treatment_T.shape))

        np_train_X, np_test_X, np_train_T, np_test_T, np_train_yf, np_test_yf, np_train_ycf, np_test_ycf = \
            Utils.test_train_split(np_covariates_X, np_treatment_T, np_outcomes_Y_f,
                                 np_outcomes_Y_cf, split_size)

        print("Numpy Train Statistics:")
        print(np_train_X.shape)
        print(np_train_T.shape)
        n_treated = np_train_T[np_train_T == 1].shape[0]
        n_total = np_train_T.shape[0]

        print("Numpy test Statistics:") 
        print(np_test_X.shape)
        print(np_test_T.shape)

        return np_train_X, np_train_T, np_train_yf, np_train_ycf, \
               np_test_X, np_test_T, np_test_yf, np_test_ycf, n_treated, n_total

    @staticmethod
    def preprocess_dataset_for_training(csv_path):
        data_X = np.loadtxt(csv_path, delimiter=",", skiprows=1)
        
        # Extract covariates: age, educ, race, married, nodegree, re74, re75
        # Normalize continuous variables
        x = np.zeros((data_X.shape[0], 7))
        
        # Continuous variables: age, educ, re74, re75  
        x[:, 0] = (data_X[:, 2] - np.mean(data_X[:, 2])) / np.std(data_X[:, 2])  # age
        x[:, 1] = (data_X[:, 3] - np.mean(data_X[:, 3])) / np.std(data_X[:, 3])  # educ
        x[:, 2] = data_X[:, 4]  # race
        x[:, 3] = data_X[:, 5]  # married
        x[:, 4] = data_X[:, 6]  # nodegree
        x[:, 5] = (data_X[:, 7] - np.mean(data_X[:, 7])) / np.std(data_X[:, 7])  # re74
        x[:, 6] = (data_X[:, 8] - np.mean(data_X[:, 8])) / np.std(data_X[:, 8])  # re75
        
        no, dim = x.shape
        
        # Get treatment assignment
        t = data_X[:, 1]
        t = Utils.convert_to_col_vector(t)
        
        # Get observed outcome (re78)
        y_obs = data_X[:, 9]
        
        # Normalize outcome
        y_obs = (y_obs - np.mean(y_obs)) / np.std(y_obs)
        
        # Assign factual outcomes
        y_f = Utils.convert_to_col_vector(y_obs)
        
        # Estimate counterfactual outcomes using treatment effect estimation
        # Calculate average treatment effect
        treated_mean = np.mean(y_obs[t.flatten() == 1])
        control_mean = np.mean(y_obs[t.flatten() == 0])
        treatment_effect = treated_mean - control_mean
        
        # Create counterfactuals based on treatment effect
        y_cf = np.where(t == 1, 
                       y_obs - treatment_effect,  # For treated: subtract effect to get control outcome
                       y_obs + treatment_effect   # For control: add effect to get treated outcome
                      ).reshape(-1, 1)

        return x, t, y_f, y_cf, no

# Neural Network Models
class Encoder_shared(nn.Module):
    def __init__(self, input_nodes=Constants.DRNET_INPUT_NODES,
                 shared_nodes=Constants.Encoder_shared_nodes):
        super().__init__()
        self.shared1 = nn.Linear(input_nodes, shared_nodes)
        self.shared2 = nn.Linear(shared_nodes, shared_nodes)
        self.shared3 = nn.Linear(shared_nodes, shared_nodes)

    def forward(self, x):
        x = F.relu(self.shared1(x))
        x = F.relu(self.shared2(x))
        x = F.relu(self.shared3(x))
        return x

class Encoder_x(nn.Module):
    def __init__(self, shared_nodes=Constants.Encoder_shared_nodes,
                 out_nodes=Constants.Encoder_x_nodes):
        super().__init__()
        self.out = nn.Linear(shared_nodes, shared_nodes)
        self.fc_mu = nn.Linear(shared_nodes, out_nodes)
        self.fc_log_var = nn.Linear(shared_nodes, out_nodes)

    def forward(self, x):
        x = F.relu(self.out(x))
        x_mu = self.fc_mu(x)
        x_log_var = self.fc_log_var(x)
        return x_mu, x_log_var

