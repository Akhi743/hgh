# Constants
class Constants:
    # Model Architecture
    DRNET_INPUT_NODES = 7  # LaLonde features: age,educ,race,married,nodegree,re74,re75
    DRNET_SHARED_NODES = 200
    DRNET_OUTPUT_NODES = 100
    
    # Training Parameters
    DRNET_EPOCHS = 50
    DRNET_LR = 1e-3
    DRNET_LAMBDA = 0.001
    DRNET_BATCH_SIZE = 64
    ALPHA = 1
    BETA = 1
    
    # VAE Parameters
    Encoder_shared_nodes = 15
    Encoder_x_nodes = 5
    Encoder_t_nodes = 1
    Encoder_yf_nodes = 1
    Encoder_ycf_nodes = 1
    
    # Decoder Parameters
    Decoder_in_nodes = Encoder_x_nodes + Encoder_t_nodes + Encoder_yf_nodes + Encoder_ycf_nodes
    Decoder_shared_nodes = DRNET_INPUT_NODES
    Decoder_out_nodes = DRNET_INPUT_NODES
    
    # GAN Parameters
    Info_GAN_Gen_in_nodes = 100
    Info_GAN_Gen_shared_nodes = 30
    Info_GAN_Gen_out_nodes = 1
    Info_GAN_Dis_in_nodes = DRNET_INPUT_NODES + 2
    Info_GAN_Dis_shared_nodes = 30
    Info_GAN_Dis_out_nodes = 1
    Info_GAN_Q_in_nodes = 2
    Info_GAN_Q_shared_nodes = 30
    Info_GAN_Q_out_nodes = Decoder_in_nodes
    
    # Training Hyperparameters
    Adversarial_epochs = 500
    Adversarial_VAE_LR = 1e-3
    INFO_GAN_G_LR = 1e-4
    INFO_GAN_D_LR = 1e-4
    Adversarial_LAMBDA = 1e-5
    Adversarial_BATCH_SIZE = 64
    VAE_BETA = 1
    INFO_GAN_LAMBDA = 0.2
    INFO_GAN_ALPHA = 1

# Utility Classes
class Utils:
    @staticmethod
    def convert_df_to_np_arr(data):
        return data.to_numpy()
    
    @staticmethod
    def convert_to_col_vector(np_arr):
        return np_arr.reshape(np_arr.shape[0], 1)
    
    @staticmethod
    def get_device():
        return torch.device("cuda:0" if torch.cuda.is_available() else "cpu")
    
    @staticmethod
    def write_to_csv(file_name, list_to_write):
        pd.DataFrame.from_dict(list_to_write, orient='columns').to_csv(file_name)
    
    @staticmethod
    def vae_loss(mu, log_var):
        return -0.5 * torch.sum(1 + log_var - mu.pow(2) - log_var.exp())

class NormalNLLLoss:
    def __call__(self, noise_z, mu, var):
        logli = -0.5 * (var.mul(2 * np.pi) + 1e-6).log() - \
                (noise_z - mu).pow(2).div(var.mul(2.0) + 1e-6)
        return -(logli.sum(1).mean())

class Metrics:
    @staticmethod
    def PEHE(y1_true, y0_true, y1_pred, y0_pred):
        return np.sqrt(np.mean(((y1_true - y0_true) - (y1_pred - y0_pred)) ** 2))

    @staticmethod
    def ATE(y1_true, y0_true, y1_pred, y0_pred):
        return np.abs(np.mean(y1_true - y0_true) - np.mean(y1_pred - y0_pred))

# Model Components
class Encoder_shared(nn.Module):
    def __init__(self, input_nodes=Constants.DRNET_INPUT_NODES,
                 shared_nodes=Constants.Encoder_shared_nodes):
        super().__init__()
        self.shared1 = nn.Linear(input_nodes, shared_nodes)
        self.shared2 = nn.Linear(shared_nodes, shared_nodes)
        self.shared3 = nn.Linear(shared_nodes, shared_nodes)
    
    def forward(self, x):
        x = F.relu(self.shared1(x))
        x = F.relu(self.shared2(x))
        x = F.relu(self.shared3(x))
        return x

class Encoder_x(nn.Module):
    def __init__(self, shared_nodes=Constants.Encoder_shared_nodes,
                 out_nodes=Constants.Encoder_x_nodes):
        super().__init__()
        self.out = nn.Linear(shared_nodes, shared_nodes)
        self.fc_mu = nn.Linear(shared_nodes, out_nodes)
        self.fc_log_var = nn.Linear(shared_nodes, out_nodes)
    
    def forward(self, x):
        x = F.relu(self.out(x))
        x_mu = self.fc_mu(x)
        x_log_var = self.fc_log_var(x)
        return x_mu, x_log_var

