class pi_net(nn.Module):
    def __init__(self, input_nodes, outcome_nodes=200):
        super().__init__()
        self.hidden1_pi = nn.Linear(input_nodes, outcome_nodes)
        self.hidden2_pi = nn.Linear(outcome_nodes, outcome_nodes)
        self.out_pi = nn.Linear(outcome_nodes, 1)

    def forward(self, x):
        if torch.cuda.is_available():
            x = x.float().cuda()
        else:
            x = x.float()
        pi = F.elu(self.hidden1_pi(x))
        pi = F.elu(self.hidden2_pi(pi))
        pi = torch.sigmoid(self.out_pi(pi))
        return pi

class mu_net(nn.Module):
    def __init__(self, input_nodes, shared_nodes=200, outcome_nodes=100):
        super().__init__()
        self.hidden1_mu = nn.Linear(input_nodes, shared_nodes)
        self.hidden2_mu = nn.Linear(shared_nodes, shared_nodes)
        self.hidden3_mu = nn.Linear(shared_nodes, outcome_nodes)
        self.hidden4_mu = nn.Linear(outcome_nodes, outcome_nodes)
        self.hidden5_mu = nn.Linear(outcome_nodes, outcome_nodes)
        self.out_mu = nn.Linear(outcome_nodes, 1)

    def forward(self, x, t):
        if torch.cuda.is_available():
            x = x.float().cuda()
        else:
            x = x.float()
        x_t = torch.cat((x, t.float()), 1)
        mu = F.elu(self.hidden1_mu(x_t))
        mu = F.elu(self.hidden2_mu(mu))
        mu = F.elu(self.hidden3_mu(mu))
        mu = F.elu(self.hidden4_mu(mu))
        mu = F.elu(self.hidden5_mu(mu))
        mu = self.out_mu(mu)
        return mu

class DRNet_Manager:
    def __init__(self, input_nodes, shared_nodes, outcome_nodes, device):
        self.dr_net_phi = DRNetPhi(input_nodes=input_nodes,
                                  shared_nodes=shared_nodes).to(device)
        self.dr_net_h_y1 = DRNetH_Y1(input_nodes=shared_nodes,
                                    outcome_nodes=outcome_nodes).to(device)
        self.dr_net_h_y0 = DRNetH_Y0(input_nodes=shared_nodes,
                                    outcome_nodes=outcome_nodes).to(device)
        self.pi_net = pi_net(input_nodes=input_nodes,
                            outcome_nodes=outcome_nodes).to(device)
        self.mu_net = mu_net(input_nodes=input_nodes + 1,
                            shared_nodes=shared_nodes,
                            outcome_nodes=outcome_nodes).to(device)

    def train_DR_NET(self, train_parameters, device):
        epochs = train_parameters["epochs"]
        batch_size = train_parameters["batch_size"]
        lr = train_parameters["lr"]
        weight_decay = train_parameters["lambda"]
        train_dataset = train_parameters["train_dataset"]
        ALPHA = train_parameters["ALPHA"]
        BETA = train_parameters["BETA"]

        train_data_loader = torch.utils.data.DataLoader(
            train_dataset,
            batch_size=batch_size,
            shuffle=True
        )

        optimizer_W = optim.Adam(self.dr_net_phi.parameters(), lr=lr)
        optimizer_V1 = optim.Adam(self.dr_net_h_y1.parameters(), lr=lr, weight_decay=weight_decay)
        optimizer_V0 = optim.Adam(self.dr_net_h_y0.parameters(), lr=lr, weight_decay=weight_decay)
        optimizer_pi = optim.Adam(self.pi_net.parameters(), lr=lr, weight_decay=weight_decay)
        optimizer_mu = optim.Adam(self.mu_net.parameters(), lr=lr, weight_decay=weight_decay)

        loss_F_MSE = nn.MSELoss()
        loss_CF_MSE = nn.MSELoss()
        loss_DR_F_MSE = nn.MSELoss()
        loss_DR_CF_MSE = nn.MSELoss()
        lossBCE = nn.BCELoss()

        for epoch in range(epochs):
            total_loss_train = 0
            with tqdm(total=len(train_data_loader)) as t:
                self.dr_net_phi.train()
                self.dr_net_h_y0.train()
                self.dr_net_h_y1.train()
                self.pi_net.train()
                self.mu_net.train()

                for batch in train_data_loader:
                    covariates_X, T, y_f, y_cf, _, _ = batch
                    covariates_X = covariates_X.to(device)
                    T = T.to(device)
                    y_f = y_f.to(device)
                    y_cf = y_cf.to(device)

                    optimizer_W.zero_grad()
                    optimizer_V1.zero_grad()
                    optimizer_V0.zero_grad()
                    optimizer_pi.zero_grad()
                    optimizer_mu.zero_grad()

                    pi = self.pi_net(covariates_X)
                    mu = self.mu_net(covariates_X, T)

                    shared_features = self.dr_net_phi(covariates_X)
                    y1_hat = self.dr_net_h_y1(shared_features)
                    y0_hat = self.dr_net_h_y0(shared_features)

                    T_float = T.float()

                    y_f_hat = y1_hat * T_float + y0_hat * (1 - T_float)
                    y_cf_hat = y1_hat * (1 - T_float) + y0_hat * T_float

                    y_f_dr = T_float * ((T_float * y1_hat - (T_float - pi) * mu) / (pi + 1e-8)) + \
                            (1 - T_float) * (((1 - T_float) * y0_hat - (T_float - pi) * mu) / (1 - pi + 1e-8))

                    y_cf_dr = (1 - T_float) * (((1 - T_float) * y1_hat - (T_float - pi) * mu) / (pi + 1e-8)) + \
                             T_float * ((T_float * y0_hat - (T_float - pi) * mu) / (1 - pi + 1e-8))

                    loss_pi = lossBCE(pi, T_float).to(device)
                    loss_F = loss_F_MSE(y_f_hat, y_f).to(device)
                    loss_CF = loss_CF_MSE(y_cf_hat, y_cf).to(device)
                    loss_DR_F = loss_DR_F_MSE(y_f_dr, y_f).to(device)
                    loss_DR_CF = loss_DR_CF_MSE(y_cf_dr, y_cf).to(device)

                    loss = loss_F + loss_CF + ALPHA * loss_pi + BETA * (loss_DR_F + loss_DR_CF)
                    loss.backward()
                    
                    total_loss_train += loss.item()

                    optimizer_pi.step()
                    optimizer_mu.step()
                    optimizer_W.step()
                    optimizer_V1.step()
                    optimizer_V0.step()

                    t.set_postfix(epoch=f'{epoch+1}/{epochs}',
                                loss=f'{total_loss_train:.3f}')
                    t.update()

    def test_DR_NET(self, test_parameters, device):
        eval_set = test_parameters["tensor_dataset"]
        self.dr_net_phi.eval()
        self.dr_net_h_y0.eval()
        self.dr_net_h_y1.eval()

        _data_loader = torch.utils.data.DataLoader(eval_set, shuffle=False)

        y1_hat_list = []
        y0_hat_list = []
        y1_true_list = []
        y0_true_list = []
        ITE_dict_list = []

        with torch.no_grad():
            for batch in _data_loader:
                covariates_X, T, yf, ycf, mu0, mu1 = batch
                covariates_X = covariates_X.to(device)
                T = T.to(device)
                yf = yf.to(device)
                ycf = ycf.to(device)
                mu0 = mu0.to(device)
                mu1 = mu1.to(device)
                
                shared_features = self.dr_net_phi(covariates_X)
                y1_hat = self.dr_net_h_y1(shared_features)
                y0_hat = self.dr_net_h_y0(shared_features)

                T_float = T.float()

                y_f_hat = y1_hat * T_float + y0_hat * (1 - T_float)
                y_cf_hat = y1_hat * (1 - T_float) + y0_hat * T_float

                y1_hat_list.append(y1_hat.cpu().item())
                y0_hat_list.append(y0_hat.cpu().item())

                y1_true = T * yf + (1 - T) * ycf
                y0_true = (1 - T) * yf + T * ycf

                y1_true_list.append(mu1.cpu().item())
                y0_true_list.append(mu0.cpu().item())

                predicted_ITE = y1_hat - y0_hat
                true_ITE = mu1 - mu0

                diff_ite = abs(true_ITE - predicted_ITE)
                diff_yf = abs(yf - y_f_hat)

                ITE_dict_list.append(self.create_ITE_Dict(
                    T.cpu().item(),
                    true_ITE.cpu().item(),
                    predicted_ITE.cpu().item(),
                    diff_ite.cpu().item(),
                    yf.cpu().item(),
                    ycf.cpu().item(),
                    y_f_hat.cpu().item(),
                    y_cf_hat.cpu().item(),
                    diff_yf.cpu().item()
                ))

        return {
            "y1_hat_list": np.array(y1_hat_list),
            "y0_hat_list": np.array(y0_hat_list),
            "y1_true_list": np.array(y1_true_list),
            "y0_true_list": np.array(y0_true_list),
            "ITE_dict_list": ITE_dict_list
        }

    @staticmethod
    def create_ITE_Dict(T, true_ite, predicted_ite, diff_ite, yf_true,
                       ycf_true, yf_hat, y_cf_hat, diff_yf):
        result_dict = OrderedDict()
        result_dict["Treatment"] = T
        result_dict["true_ite"] = true_ite
        result_dict["predicted_ite"] = predicted_ite
        result_dict["diff_ite"] = diff_ite
        result_dict["yf_true"] = yf_true
        result_dict["ycf_true"] = ycf_true
        result_dict["yf_hat"] = yf_hat
        result_dict["y_cf_hat"] = y_cf_hat
        result_dict["diff_yf"] = diff_yf
        return result_dict

class LaLondeDataLoader:
    def load_train_test_lalonde_random(self, csv_path, split_size):
        # Read data
        df = pd.read_csv(csv_path)
        
        # Convert categorical variables
        df['race'] = df['race'].map({'white': 0, 'black': 1, 'hispan': 2})
        
        # Define features
        feature_cols = ['age', 'educ', 'race', 'married', 'nodegree', 're74', 're75']
        
        # Standardize features
        scaler = StandardScaler()
        df[feature_cols] = scaler.fit_transform(df[feature_cols])
        
        # Extract arrays
        X = df[feature_cols].values
        T = df['treat'].values.reshape(-1, 1)  # Treatment
        Y = df['re78'].values.reshape(-1, 1)   # Outcome
        
        # Split data
        train_size = int(split_size * len(df))
        indices = np.random.permutation(len(df))
        
        train_idx = indices[:train_size]
        test_idx = indices[train_size:]
        
        # Training data
        train_X = X[train_idx]
        train_T = T[train_idx]
        train_Y = Y[train_idx]
        
        # Create counterfactuals (zeros as placeholders since we don't have true counterfactuals)
        train_Ycf = np.zeros_like(train_Y)
        train_mu0 = np.zeros_like(train_Y)
        train_mu1 = np.zeros_like(train_Y)
        
        # Test data
        test_X = X[test_idx]
        test_T = T[test_idx]
        test_Y = Y[test_idx]
        test_Ycf = np.zeros_like(test_Y)
        test_mu0 = np.zeros_like(test_Y)
        test_mu1 = np.zeros_like(test_Y)
        
        n_treated = np.sum(train_T)
        n_total = len(train_T)
        
        return (train_X, train_T, train_Y, train_Ycf,
                test_X, test_T, test_Y, test_Ycf,
                train_mu0, test_mu0, train_mu1, test_mu1,
                n_treated, n_total)

