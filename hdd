class Decoder(nn.Module):
    def __init__(self, in_nodes=Constants.Decoder_in_nodes,
                 shared_nodes=Constants.Decoder_shared_nodes,
                 out_nodes=Constants.Decoder_out_nodes):
        super().__init__()
        self.shared1 = nn.Linear(in_nodes, shared_nodes)
        self.shared2 = nn.Linear(shared_nodes, shared_nodes)
        self.shared3 = nn.Linear(shared_nodes, shared_nodes)
        self.out_nodes = nn.Linear(shared_nodes, out_nodes)
    
    def forward(self, x):
        x = F.relu(self.shared1(x))
        x = F.relu(self.shared2(x))
        x = F.relu(self.shared3(x))
        return self.out_nodes(x)

class Adversarial_VAE(nn.Module):
    def __init__(self, encoder_input_nodes=Constants.DRNET_INPUT_NODES,
                 encoder_shared_nodes=Constants.Encoder_shared_nodes,
                 encoder_x_out_nodes=Constants.Encoder_x_nodes,
                 encoder_t_out_nodes=Constants.Encoder_t_nodes,
                 encoder_yf_out_nodes=Constants.Encoder_yf_nodes,
                 encoder_ycf_out_nodes=Constants.Encoder_ycf_nodes,
                 decoder_in_nodes=Constants.Decoder_in_nodes,
                 decoder_shared_nodes=Constants.Decoder_shared_nodes,
                 decoder_out_nodes=Constants.Decoder_out_nodes):
        super().__init__()
        self.encoder_shared = Encoder_shared(input_nodes=encoder_input_nodes,
                                           shared_nodes=encoder_shared_nodes)
        self.encoder_x = Encoder_x(shared_nodes=encoder_shared_nodes,
                                 out_nodes=encoder_x_out_nodes)
        self.encoder_t = Encoder_t(shared_nodes=encoder_shared_nodes,
                                 out_nodes=encoder_t_out_nodes)
        self.encoder_yf = Encoder_yf(shared_nodes=encoder_shared_nodes,
                                   out_nodes=encoder_yf_out_nodes)
        self.encoder_ycf = Encoder_ycf(shared_nodes=encoder_shared_nodes,
                                     out_nodes=encoder_ycf_out_nodes)
        self.decoder = Decoder(in_nodes=decoder_in_nodes,
                             shared_nodes=decoder_shared_nodes,
                             out_nodes=decoder_out_nodes)

    def re_parametrize(self, mu, log_var):
        if self.training:
            std = log_var.mul(0.5).exp_()
            eps = torch.empty_like(std).normal_()
            return mu + eps * std
        else:
            return mu

    def forward(self, x):
        latent_mu_x, latent_log_var_x = self.encoder_x(self.encoder_shared(x))
        latent_mu_t, latent_log_var_t = self.encoder_t(self.encoder_shared(x))
        latent_mu_yf, latent_log_var_yf = self.encoder_yf(self.encoder_shared(x))
        latent_mu_ycf, latent_log_var_ycf = self.encoder_ycf(self.encoder_shared(x))

        latent_z_x = self.re_parametrize(latent_mu_x, latent_log_var_x)
        latent_z_t = self.re_parametrize(latent_mu_t, latent_log_var_t)
        latent_z_yf = self.re_parametrize(latent_mu_yf, latent_log_var_yf)
        latent_z_ycf = self.re_parametrize(latent_mu_ycf, latent_log_var_ycf)

        latent_z = torch.cat((latent_z_x, latent_z_t, latent_z_yf, latent_z_ycf), 1)
        x_hat = self.decoder(latent_z)

        return x_hat, latent_z, \
               latent_mu_x, latent_log_var_x, \
               latent_mu_t, latent_log_var_t, \
               latent_mu_yf, latent_log_var_yf, \
               latent_mu_ycf, latent_log_var_ycf

class Generator(nn.Module):
    def __init__(self, in_nodes=Constants.Info_GAN_Gen_in_nodes,
                 shared_nodes=Constants.Info_GAN_Gen_shared_nodes,
                 out_nodes=Constants.Info_GAN_Gen_out_nodes):
        super().__init__()
        self.shared1 = nn.Linear(in_nodes, shared_nodes)
        self.shared2 = nn.Linear(shared_nodes, shared_nodes)
        self.hidden_y0 = nn.Linear(shared_nodes, shared_nodes)
        self.out_y0 = nn.Linear(shared_nodes, out_nodes)
        self.hidden_y1 = nn.Linear(shared_nodes, shared_nodes)
        self.out_y1 = nn.Linear(shared_nodes, out_nodes)

    def forward(self, y):
        y = F.relu(self.shared1(y))
        y = F.relu(self.shared2(y))
        
        y0 = F.relu(self.hidden_y0(y))
        y0 = self.out_y0(y0)
        
        y1 = F.relu(self.hidden_y1(y))
        y1 = self.out_y1(y1)
        
        return y0, y1

class Discriminator(nn.Module):
    def __init__(self, in_nodes=Constants.Info_GAN_Dis_in_nodes,
                 shared_nodes=Constants.Info_GAN_Dis_shared_nodes,
                 out_nodes=Constants.Info_GAN_Dis_out_nodes):
        super().__init__()
        self.hidden1 = nn.Linear(in_nodes, shared_nodes)
        self.hidden2 = nn.Linear(shared_nodes, shared_nodes)
        self.out = nn.Linear(shared_nodes, out_nodes)

    def forward(self, x, y0, y1):
        x_t = torch.cat((x, y0, y1), 1)
        x_t = F.relu(self.hidden1(x_t))
        x_t = F.relu(self.hidden2(x_t))
        return torch.sigmoid(self.out(x_t))

class QHead(nn.Module):
    def __init__(self, in_nodes=Constants.Info_GAN_Q_in_nodes,
                 shared_nodes=Constants.Info_GAN_Q_shared_nodes,
                 out_nodes=Constants.Info_GAN_Q_out_nodes):
        super().__init__()
        self.hidden1 = nn.Linear(in_nodes, shared_nodes)
        self.hidden2 = nn.Linear(shared_nodes, shared_nodes)
        self.out_mu0 = nn.Linear(shared_nodes, out_nodes)
        self.out_var0 = nn.Linear(shared_nodes, out_nodes)

    def forward(self, x):
        x = F.relu(self.hidden1(x))
        x = F.relu(self.hidden2(x))
        mu0 = self.out_mu0(x).squeeze()
        var0 = torch.exp(self.out_var0(x).squeeze())
        return mu0, var0

# Add gradient clipping and numerical stability improvements
class Adversarial_Manager:
    def __init__(self, encoder_input_nodes, encoder_shared_nodes,
                 encoder_x_out_nodes, encoder_t_out_nodes,
                 encoder_yf_out_nodes, encoder_ycf_out_nodes,
                 decoder_in_nodes, decoder_shared_nodes,
                 decoder_out_nodes,
                 gen_in_nodes, gen_shared_nodes, gen_out_nodes,
                 dis_in_nodes, dis_shared_nodes, dis_out_nodes,
                 Q_in_nodes, Q_shared_nodes, Q_out_nodes,
                 device):
        # Existing initialization code remains the same
        self.adversarial_vae = Adversarial_VAE(
            encoder_input_nodes=encoder_input_nodes,
            encoder_shared_nodes=encoder_shared_nodes,
            encoder_x_out_nodes=encoder_x_out_nodes,
            encoder_t_out_nodes=encoder_t_out_nodes,
            encoder_yf_out_nodes=encoder_yf_out_nodes,
            encoder_ycf_out_nodes=encoder_ycf_out_nodes,
            decoder_in_nodes=decoder_in_nodes,
            decoder_shared_nodes=decoder_shared_nodes,
            decoder_out_nodes=decoder_out_nodes).to(device)

        self.netG = Generator(
            in_nodes=gen_in_nodes,
            shared_nodes=gen_shared_nodes,
            out_nodes=gen_out_nodes).to(device)

        self.netD = Discriminator(
            in_nodes=dis_in_nodes,
            shared_nodes=dis_shared_nodes,
            out_nodes=dis_out_nodes).to(device)

        self.netQ = QHead(
            in_nodes=Q_in_nodes,
            shared_nodes=Q_shared_nodes,
            out_nodes=Q_out_nodes).to(device)

    def train_adversarial_model(self, train_parameters, device):
        # Add gradient clipping threshold
        max_grad_norm = 1.0
        
        epochs = train_parameters["epochs"]
        batch_size = train_parameters["batch_size"]
        vae_lr = train_parameters["vae_lr"]
        gan_G_lr = train_parameters["gan_G_lr"]
        gan_D_lr = train_parameters["gan_D_lr"]
        weight_decay = train_parameters["lambda"]
        train_dataset = train_parameters["train_dataset"]
        VAE_BETA = train_parameters["VAE_BETA"]
        INFO_GAN_LAMBDA = train_parameters["INFO_GAN_LAMBDA"]
        INFO_GAN_ALPHA = train_parameters["INFO_GAN_ALPHA"]

        train_data_loader = torch.utils.data.DataLoader(
            train_dataset,
            batch_size=batch_size,
            shuffle=True
        )

        # Add gradient clipping to optimizers
        adv_vae_optimizer = optim.Adam(
            self.adversarial_vae.parameters(),
            lr=vae_lr,
            weight_decay=weight_decay
        )

        D_optimizer = optim.Adam(
            self.netD.parameters(),
            lr=gan_D_lr,
            weight_decay=weight_decay,
            betas=(0.5, 0.999)
        )

        G_optimizer = optim.Adam(
            list(self.netG.parameters()) + list(self.netQ.parameters()),
            lr=gan_G_lr,
            weight_decay=weight_decay,
            betas=(0.5, 0.999)
        )

        # Modified loss functions with numerical stability
        loss_VAE_recons_MSE = nn.MSELoss()
        loss_Q_con = NormalNLLLoss()
        loss_D = nn.BCEWithLogitsLoss()  # Changed from BCELoss for improved stability
        loss_G_F = nn.MSELoss()

        for epoch in range(epochs):
            total_loss_train = 0
            with tqdm(total=len(train_data_loader)) as t:
                for batch in train_data_loader:
                    batch_size = batch[0].size(0)
                    
                    # Move data to device
                    real_x = batch[0].to(device)
                    real_t = batch[1].to(device)
                    real_yf = batch[2].to(device)
                    
                    # Train VAE with gradient clipping
                    self.adversarial_vae.train()
                    adv_vae_optimizer.zero_grad()
                    
                    [x_recon, latent_z, mu_x, logvar_x,
                     mu_t, logvar_t, mu_yf, logvar_yf,
                     mu_ycf, logvar_ycf] = self.adversarial_vae(real_x)
                    
                    # VAE losses with improved numerical stability
                    recon_loss = loss_VAE_recons_MSE(x_recon, real_x)
                    kl_loss = VAE_BETA * (
                        Utils.vae_loss(mu_x, torch.clamp(logvar_x, min=-20, max=20)) +
                        Utils.vae_loss(mu_t, torch.clamp(logvar_t, min=-20, max=20)) +
                        Utils.vae_loss(mu_yf, torch.clamp(logvar_yf, min=-20, max=20)) +
                        Utils.vae_loss(mu_ycf, torch.clamp(logvar_ycf, min=-20, max=20))
                    )
                    
                    vae_loss = recon_loss + kl_loss
                    if not torch.isnan(vae_loss):
                        vae_loss.backward()
                        torch.nn.utils.clip_grad_norm_(self.adversarial_vae.parameters(), max_grad_norm)
                        adv_vae_optimizer.step()

                    # Train Discriminator with gradient clipping
                    self.netD.train()
                    D_optimizer.zero_grad()
                    
                    # Generate fake data
                    noise = torch.randn(batch_size, Constants.Info_GAN_Gen_in_nodes - Constants.Decoder_in_nodes).to(device)
                    latent_z_detached = latent_z.detach()
                    fake_input = torch.cat([latent_z_detached, noise], dim=1)
                    
                    fake_y0, fake_y1 = self.netG(fake_input)
                    
                    # Real and fake labels with label smoothing
                    real_label = torch.ones(batch_size, 1).to(device) * 0.9  # Label smoothing
                    fake_label = torch.zeros(batch_size, 1).to(device) + 0.1  # Label smoothing
                    
                    # Discriminator training with improved stability
                    real_y0 = ((1 - real_t) * real_yf).detach()
                    real_y1 = (real_t * real_yf).detach()
                    d_real = self.netD(real_x, real_y0, real_y1)
                    d_fake = self.netD(real_x, fake_y0.detach(), fake_y1.detach())
                    
                    d_loss = (loss_D(d_real, real_label) + loss_D(d_fake, fake_label)) / 2
                    if not torch.isnan(d_loss):
                        d_loss.backward()
                        torch.nn.utils.clip_grad_norm_(self.netD.parameters(), max_grad_norm)
                        D_optimizer.step()

                    # Train Generator with gradient clipping
                    self.netG.train()
                    self.netQ.train()
                    G_optimizer.zero_grad()
                    
                    fake_y0, fake_y1 = self.netG(fake_input)
                    g_fake = self.netD(real_x, fake_y0, fake_y1)
                    
                    # Q Network
                    q_input = torch.cat([fake_y0, fake_y1], dim=1)
                    q_mu, q_var = self.netQ(q_input)
                    q_loss = loss_Q_con(latent_z_detached, q_mu, torch.clamp(q_var, min=1e-6))
                    
                    # Generator losses
                    g_loss = loss_D(g_fake, real_label)
                    f_loss = loss_G_F(fake_y0 * (1 - real_t) + fake_y1 * real_t, real_yf)
                    
                    g_total_loss = g_loss + INFO_GAN_ALPHA * f_loss + INFO_GAN_LAMBDA * q_loss
                    if not torch.isnan(g_total_loss):
                        g_total_loss.backward()
                        torch.nn.utils.clip_grad_norm_(self.netG.parameters(), max_grad_norm)
                        torch.nn.utils.clip_grad_norm_(self.netQ.parameters(), max_grad_norm)
                        G_optimizer.step()

                    # Update progress bar only for valid losses
                    if not any(torch.isnan(x) for x in [vae_loss, d_loss, g_total_loss]):
                        total_loss = vae_loss.item() + d_loss.item() + g_total_loss.item()
                        total_loss_train += total_loss
                        
                        t.set_postfix(
                            epoch=f'{epoch+1}/{epochs}',
                            vae_loss=f'{vae_loss.item():.3f}',
                            d_loss=f'{d_loss.item():.3f}',
                            g_loss=f'{g_total_loss.item():.3f}',
                            total=f'{total_loss:.3f}'
                        )
                    t.update()

        # Save models
        torch.save(self.adversarial_vae.state_dict(), "Models/adversarial_vae.pth")
        torch.save(self.netG.state_dict(), "Models/netG.pth")
        torch.save(self.netD.state_dict(), "Models/netD.pth")
        torch.save(self.netQ.state_dict(), "Models/netQ0.pth")

    def test_adversarial_model(self, test_parameters, device):
        eval_set = test_parameters["tensor_dataset"]
        _data_loader = torch.utils.data.DataLoader(eval_set, shuffle=False)

        self.adversarial_vae.eval()
        self.netG.eval()
        self.netD.eval()
        self.netQ.eval()

        ycf_list = []
        
        with torch.no_grad():
            for batch in _data_loader:
                covariates_X, T, y_f, _, _, _ = batch
                batch_n = covariates_X.size(0)
                covariates_X = covariates_X.to(device)

                # VAE forward pass
                [_, latent_z, _, _, _, _, _, _, _, _] = self.adversarial_vae(covariates_X)

                # GAN forward pass
                noise = torch.randn(batch_n, Constants.Info_GAN_Gen_in_nodes - Constants.Decoder_in_nodes).to(device)
                fake_input = torch.cat([latent_z, noise], dim=1)
                
                y0, y1 = self.netG(fake_input)
                T = T.to(device)
                y_cf = T * y0 + (1 - T) * y1
                ycf_list.append(y_cf.cpu().item())

        return Utils.convert_to_col_vector(np.array(ycf_list))

class DRNetPhi(nn.Module):
    def __init__(self, input_nodes, shared_nodes=200):
        super().__init__()
        self.shared1 = nn.Linear(input_nodes, shared_nodes)
        self.shared2 = nn.Linear(shared_nodes, shared_nodes)
        self.shared3 = nn.Linear(shared_nodes, shared_nodes)

    def forward(self, x):
        if torch.cuda.is_available():
            x = x.float().cuda()
        else:
            x = x.float()
        x = F.elu(self.shared1(x))
        x = F.elu(self.shared2(x))
        x = F.elu(self.shared3(x))
        return x

