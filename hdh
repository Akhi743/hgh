class Utils:
    @staticmethod
    def convert_df_to_np_arr(data):
        return data.to_numpy()

    @staticmethod
    def convert_to_col_vector(np_arr):
        return np_arr.reshape(np_arr.shape[0], 1)

    @staticmethod
    def test_train_split(np_train_X, np_train_T, np_train_yf, np_train_ycf,
                         np_mu0, np_mu1, split_size=0.8):
        return sklearn.train_test_split(np_train_X, np_train_T, np_train_yf, np_train_ycf,
                                      np_mu0, np_mu1, train_size=split_size)

    @staticmethod
    def convert_to_tensor(X, T, Y_f, Y_cf, np_train_mu0, np_train_mu1):
        # Convert LaLonde features to tensors
        tensor_x = torch.FloatTensor(X)  # Changed from stack to direct conversion
        tensor_T = torch.FloatTensor(T)  # Changed from from_numpy for consistency
        tensor_y_f = torch.FloatTensor(Y_f)
        tensor_y_cf = torch.FloatTensor(Y_cf)
        tensor_mu0 = torch.FloatTensor(np_train_mu0)
        tensor_mu1 = torch.FloatTensor(np_train_mu1)

        return torch.utils.data.TensorDataset(tensor_x, tensor_T, tensor_y_f, 
                                            tensor_y_cf, tensor_mu0, tensor_mu1)

    @staticmethod
    def get_device():
        return torch.device("cuda:0" if torch.cuda.is_available() else "cpu")

    @staticmethod
    def write_to_csv(file_name, list_to_write):
        pd.DataFrame.from_dict(list_to_write, orient='columns').to_csv(file_name)

    @staticmethod
    def vae_loss(mu, log_var):
        return -0.5 * torch.sum(1 + log_var - mu.pow(2) - log_var.exp())

class NormalNLLLoss:
    def __call__(self, noise_z, mu, var):
        logli = -0.5 * (var.mul(2 * np.pi) + 1e-6).log() - \
                (noise_z - mu).pow(2).div(var.mul(2.0) + 1e-6)
        nll = -(logli.sum(1).mean())
        return nll

class EarlyStopping_DCN:
    def __init__(self, patience=7, verbose=False, delta=0,
                 dr_net_shared_path="Models/LaLonde/dr_net_phi.pth",
                 dr_net_y1_path="Models/LaLonde/dr_net_y1.pth",
                 dr_net_y0_path="Models/LaLonde/dr_net_y0.pth",
                 pi_net_path="Models/LaLonde/pi_net.pth",
                 mu_net_path="Models/LaLonde/mu_net.pth",
                 trace_func=print):
        self.patience = patience
        self.verbose = verbose
        self.counter = 0
        self.best_score = None
        self.early_stop = False
        self.val_loss_min = np.Inf
        self.delta = delta
        self.dr_net_shared_path = dr_net_shared_path
        self.dr_net_y1_path = dr_net_y1_path
        self.dr_net_y0_path = dr_net_y0_path
        self.pi_net_path = pi_net_path
        self.mu_net_path = mu_net_path
        self.trace_func = trace_func

    def __call__(self, val_loss, dr_net_shared, dr_net_y1_model, dr_net_y0_model,
                 pi_net_model, mu_net_model):
        score = -val_loss
        if self.best_score is None:
            self.best_score = score
            self.save_checkpoint(val_loss, dr_net_shared, dr_net_y1_model, 
                               dr_net_y0_model, pi_net_model, mu_net_model)
        elif score < self.best_score + self.delta:
            self.counter += 1
            self.trace_func(f'EarlyStopping counter: {self.counter} out of {self.patience}')
            if self.counter >= self.patience:
                self.early_stop = True
        else:
            self.best_score = score
            self.save_checkpoint(val_loss, dr_net_shared, dr_net_y1_model,
                               dr_net_y0_model, pi_net_model, mu_net_model)
            self.counter = 0

    def save_checkpoint(self, val_loss, dr_net_shared, dr_net_y1_model, dr_net_y0_model,
                       pi_net_model, mu_net_model):
        if self.verbose:
            self.trace_func(f'Validation loss decreased ({self.val_loss_min} --> {val_loss}). Saving model ...')
        torch.save(dr_net_shared.state_dict(), self.dr_net_shared_path)
        torch.save(dr_net_y1_model.state_dict(), self.dr_net_y1_path)
        torch.save(dr_net_y0_model.state_dict(), self.dr_net_y0_path)
        torch.save(pi_net_model.state_dict(), self.pi_net_path)
        torch.save(mu_net_model.state_dict(), self.mu_net_path)
        self.val_loss_min = val_loss











import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
import torch

class DataLoader:
    def load_train_test_ihdp_random(self, csv_path, split_size):
        df = pd.read_csv(csv_path)
        
        # Convert features to binary
        df['race'] = (df['race'] != 'white').astype(int)  # 1 if not white, 0 if white
        df['married'] = df['married'].astype(int)  # Already binary
        df['nodegree'] = df['nodegree'].astype(int)  # Already binary
        df['treat'] = df['treat'].astype(int)  # Already binary
        
        # Binarize continuous variables using median
        continuous_cols = ['age', 'educ', 're74', 're75']
        for col in continuous_cols:
            median = df[col].median()
            df[col] = (df[col] > median).astype(int)
        
        feature_cols = ['age', 'educ', 'race', 'married', 'nodegree', 're74', 're75']
        
        X = df[feature_cols].values
        T = df['treat'].values.reshape(-1, 1)
        Y = (df['re78'] > df['re78'].median()).astype(int).values.reshape(-1, 1)
        
        train_size = int(split_size * len(df))
        indices = np.random.permutation(len(df))
        
        train_idx = indices[:train_size]
        test_idx = indices[train_size:]
        
        train_X = X[train_idx]
        train_T = T[train_idx]
        train_Y = Y[train_idx]
        train_Ycf = np.zeros_like(train_Y)
        train_mu0 = np.zeros_like(train_Y)
        train_mu1 = np.zeros_like(train_Y)
        
        test_X = X[test_idx]
        test_T = T[test_idx]
        test_Y = Y[test_idx]
        test_Ycf = np.zeros_like(test_Y)
        test_mu0 = np.zeros_like(test_Y)
        test_mu1 = np.zeros_like(test_Y)
        
        n_treated = np.sum(train_T)
        n_total = len(train_T)
        
        return (train_X, train_T, train_Y, train_Ycf,
                test_X, test_T, test_Y, test_Ycf,
                train_mu0, test_mu0, train_mu1, test_mu1,
                n_treated, n_total)
