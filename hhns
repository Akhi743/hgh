matched_pairs = []
    used_control_indices = set()
    unmatched_treated = 0
    
    for i, (dist, idx) in enumerate(zip(distances, indices)):
        current_matches = []
        treated_pscore = treated_pscores[i][0]
        
        # Try to find MATCHING_RATIO controls for current treated unit
        for d, control_idx in zip(dist, idx):
            if len(current_matches) >= MATCHING_RATIO:
                break
                
            if control_idx == -1:
                continue
                
            control_pscore = control_pscores[control_idx][0]
            ps_diff = abs(treated_pscore - control_pscore)
            
            if ps_diff <= caliper and control_idx not in used_control_indices:
                current_matches.append(control_idx)
                used_control_indices.add(control_idx)
        
        # Only add if we found enough matches
        if len(current_matches) == MATCHING_RATIO:
            matched_pairs.append(treatment_df.index[i])  # Store treated index
            matched_pairs.extend([control_df.index[idx] for idx in current_matches])  # Store control indices
        else:
            unmatched_treated += 1

    # Create final matched dataset
    matched_df = df_encoded.loc[matched_pairs].copy()
