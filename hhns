import pandas as pd
import numpy as np
from sklearn.linear_model import LogisticRegression
import faiss
import time
import warnings

warnings.filterwarnings('ignore')

# Config
DATA_PATH = "marketing_test_case.csv"  # Path to your input data file
X_VARIABLES = ["age", "gender_cd", "social_risk_score", "hpd_hyp", "hpd_hyc", "hpd_ast", "hpd_dia"]  # Features to use
TREATMENT_VAR = "grp_binary"  # Name of treatment/control indicator column
OUTCOME_VAR = "social_risk_score"  # Name of outcome variable
MATCHING_RATIO = 2  # Number of control units per treatment unit
N_NEIGHBORS = 5  # Number of neighbors for KNN matching
CALIPER_SD = 0.25  # Caliper size in standard deviations of propensity score


class Timer:
    def __init__(self, description):
        self.description = description

    def __enter__(self):
        self.start = time.time()
        return self

    def __exit__(self, *args):
        self.end = time.time()
        self.duration = self.end - self.start
        print(f"{self.description}: {self.duration:.4f} seconds")


# Function to run the analysis
def run_analysis(data, gender_label):
    print(f"\nRunning analysis for {gender_label} dataset...")

    # Handle missing values
    data_clean = data.copy()
    for col in X_VARIABLES:
        if data_clean[col].dtype in ['int64', 'float64']:
            data_clean[col] = data_clean[col].fillna(data_clean[col].median())
        else:
            data_clean[col] = data_clean[col].fillna(data_clean[col].mode()[0])

    # Create dummy variables
    with Timer("Creating dummy variables"):
        data_encoded = data_clean.copy()
        categorical_cols = []

        for col in X_VARIABLES:
            if col in data_encoded.columns:
                if data_encoded[col].dtype == 'object' or data_encoded[col].nunique() < 10:
                    categorical_cols.append(col)
                    unique_vals = data_encoded[col].dropna().unique()
                    for val in unique_vals:
                        col_name = f"{col}_{val}"
                        data_encoded[col_name] = (data_encoded[col] == val).astype(int)
                    data_encoded = data_encoded.drop(columns=[col])

        features_for_model = [col for col in X_VARIABLES if col not in categorical_cols]
        for col in categorical_cols:
            dummy_cols = [c for c in data_encoded.columns if c.startswith(col + '_')]
            features_for_model.extend(dummy_cols)

    # Handle remaining missing values
    data_encoded = data_encoded.dropna(subset=features_for_model + [TREATMENT_VAR, OUTCOME_VAR])

    # Step 2: Propensity Score Calculation
    with Timer("Calculating propensity scores"):
        model = LogisticRegression(
            penalty='l2',
            C=1e6,
            solver='lbfgs',
            random_state=42,
            max_iter=1000
        )
        model.fit(data_encoded[features_for_model], data_encoded[TREATMENT_VAR])
        ps = model.predict_proba(data_encoded[features_for_model])[:, 1]
        data_encoded['pscore'] = ps

    # Step 3: Matching
    caliper = np.std(data_encoded['pscore']) * CALIPER_SD

    treatment_df = data_encoded[data_encoded[TREATMENT_VAR] == 1].copy()
    control_df = data_encoded[data_encoded[TREATMENT_VAR] == 0].copy()

    with Timer(f"Matching process for {len(treatment_df)} treated units"):
        treated_pscores = treatment_df['pscore'].values.reshape(-1, 1).astype('float32')
        control_pscores = control_df['pscore'].values.reshape(-1, 1).astype('float32')

        dimension = 1
        m = 16
        ef_construction = 40

        index = faiss.IndexHNSWFlat(dimension, m)
        index.hnsw.efConstruction = ef_construction
        index.add(control_pscores)

        ef_search = 10
        index.hnsw.efSearch = ef_search

        k = min(N_NEIGHBORS, len(control_df))
        distances, indices = index.search(treated_pscores, k)

        matched_pairs = []
        used_control_indices = set()
        unmatched_treated = 0

        for i, (dist, idx) in enumerate(zip(distances, indices)):
            matched_controls = []
            treated_pscore = treated_pscores[i][0]

            for d, control_idx in zip(dist, idx):
                if len(matched_controls) >= MATCHING_RATIO:
                    break
                if control_idx == -1:
                    continue
                control_pscore = control_pscores[control_idx][0]
                ps_diff = abs(treated_pscore - control_pscore)
                if ps_diff <= caliper and control_idx not in used_control_indices:
                    matched_controls.append(control_idx)
                    used_control_indices.add(control_idx)

            if len(matched_controls) == MATCHING_RATIO:
                matched_pairs.append(treatment_df.iloc[i])
                for control_idx in matched_controls:
                    matched_pairs.append(control_df.iloc[control_idx])
            else:
                unmatched_treated += 1

        print(f"Successfully matched treated units: {len(matched_pairs) // (MATCHING_RATIO + 1)}")
        print(f"Unmatched treated units: {unmatched_treated}")
        print(f"Total matched control units: {len(matched_pairs) - (len(matched_pairs) // (MATCHING_RATIO + 1))}")

    matched_df = pd.DataFrame(matched_pairs)

    # Step 4: Analysis
    ate = matched_df[matched_df[TREATMENT_VAR] == 1][OUTCOME_VAR].mean() - \
          matched_df[matched_df[TREATMENT_VAR] == 0][OUTCOME_VAR].mean()

    print(f"\n{gender_label} Results:")
    print(f"Average Treatment Effect: {ate:.4f}")


# Main Script
print(f"\nLoading data from {DATA_PATH}...")
df = pd.read_csv(DATA_PATH)

# Ensure gender_cd is properly formatted
df['gender_cd'] = df['gender_cd'].str.strip().str.title()  # Clean and normalize strings

# Split data into male and female subsets
male_df = df[df['gender_cd'] == 'Male'].copy()
female_df = df[df['gender_cd'] == 'Female'].copy()

# Run the analysis for male and female subsets
run_analysis(male_df, "Male")
run_analysis(female_df, "Female")
