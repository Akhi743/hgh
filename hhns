import pandas as pd
import numpy as np
from sklearn.linear_model import LogisticRegression
import faiss
import warnings
warnings.filterwarnings('ignore')

# Config
DATA_PATH = "marketing_test_case.csv"
X_VARIABLES = ["age", "social_risk_score", "hpd_hyp", "hpd_hyc", "hpd_ast", "hpd_dia"]
TREATMENT_VAR = "grp_binary"
OUTCOME_VAR = "social_risk_score"
MATCHING_RATIO = 2
N_NEIGHBORS = 5
CALIPER_SD = 0.25

def preprocess_data(df_subset):
    """Handle missing values and create dummy variables"""
    # Handle missing values
    df_clean = df_subset.copy()
    for col in X_VARIABLES:
        if df_clean[col].dtype in ['int64', 'float64']:
            df_clean[col] = df_clean[col].fillna(df_clean[col].median())
        else:
            df_clean[col] = df_clean[col].fillna(df_clean[col].mode()[0])
            
    return df_clean

def create_dummy_variables(df_clean):
    """Create dummy variables for categorical features"""
    df_encoded = df_clean.copy()
    categorical_cols = []
    
    for col in X_VARIABLES:
        if col in df_encoded.columns:
            if df_encoded[col].nunique() == 2 and df_encoded[col].dtype in ['int64', 'float64']:
                df_encoded[col] = df_encoded[col].map({0: 'A', 1: 'B'})
            
            if df_encoded[col].dtype == 'object' or df_encoded[col].nunique() < 10:
                categorical_cols.append(col)
                unique_vals = df_encoded[col].dropna().unique()
                
                for val in unique_vals:
                    col_name = f"{col}_{val}"
                    df_encoded[col_name] = (df_encoded[col] == val).astype(int)
                
                df_encoded = df_encoded.drop(columns=[col])
                
    return df_encoded, categorical_cols

def calculate_propensity_scores(df_encoded, features_for_model):
    """Calculate propensity scores using logistic regression"""
    model = LogisticRegression(penalty='l2', C=1e6, solver='lbfgs', random_state=42, max_iter=1000)
    model.fit(df_encoded[features_for_model], df_encoded[TREATMENT_VAR])
    return model.predict_proba(df_encoded[features_for_model])[:, 1]

def perform_matching(treatment_df, control_df, caliper):
    """Perform nearest neighbor matching using FAISS"""
    treated_pscores = treatment_df['pscore'].values.reshape(-1, 1).astype('float32')
    control_pscores = control_df['pscore'].values.reshape(-1, 1).astype('float32')
    
    dimension = 1
    index = faiss.IndexHNSWFlat(dimension, 16)
    index.hnsw.efConstruction = 40
    index.add(control_pscores)
    
    index.hnsw.efSearch = 10
    k = min(N_NEIGHBORS, len(control_df))
    distances, indices = index.search(treated_pscores, k)
    
    return distances, indices

def find_matches(distances, indices, treatment_df, control_df, caliper):
    """Find matching pairs within caliper"""
    matched_pairs = []
    used_control_indices = set()
    unmatched_treated = 0
    
    for i, (dist, idx) in enumerate(zip(distances, indices)):
        matched_controls = []
        treated_pscore = treatment_df['pscore'].iloc[i]
        
        for d, control_idx in zip(dist, idx):
            if len(matched_controls) >= MATCHING_RATIO:
                break
            
            if control_idx == -1:
                continue
            
            control_pscore = control_df['pscore'].iloc[control_idx]
            ps_diff = abs(treated_pscore - control_pscore)
            
            if ps_diff <= caliper and control_idx not in used_control_indices:
                matched_controls.append(control_idx)
                used_control_indices.add(control_idx)
        
        if len(matched_controls) == MATCHING_RATIO:
            matched_pairs.append(treatment_df.iloc[i])
            for control_idx in matched_controls:
                matched_pairs.append(control_df.iloc[control_idx])
        else:
            unmatched_treated += 1
            
    return matched_pairs, unmatched_treated

def calculate_ate(matched_df):
    """Calculate Average Treatment Effect"""
    ate = matched_df[matched_df[TREATMENT_VAR] == 1][OUTCOME_VAR].mean() - \
          matched_df[matched_df[TREATMENT_VAR] == 0][OUTCOME_VAR].mean()
    return ate

def run_analysis(df_subset, gender):
    """Main analysis function"""
    print(f"\nAnalyzing {gender} subset...")
    
    # Preprocessing
    df_clean = preprocess_data(df_subset)
    
    # Feature engineering
    df_encoded, categorical_cols = create_dummy_variables(df_clean)
    
    # Drop gender_cd_bin if exists
    if 'gender_cd_bin' in df_encoded.columns:
        df_encoded = df_encoded.drop(columns=['gender_cd_bin'])
    
    # Prepare features for model
    features_for_model = [col for col in X_VARIABLES if col not in categorical_cols]
    for col in categorical_cols:
        dummy_cols = [c for c in df_encoded.columns if c.startswith(col + '_')]
        features_for_model.extend(dummy_cols)
    
    # Handle remaining missing values
    df_encoded = df_encoded.dropna(subset=features_for_model + [TREATMENT_VAR, OUTCOME_VAR])
    
    # Calculate propensity scores
    ps = calculate_propensity_scores(df_encoded, features_for_model)
    df_encoded['pscore'] = ps
    
    # Prepare for matching
    caliper = np.std(df_encoded['pscore']) * CALIPER_SD
    treatment_df = df_encoded[df_encoded[TREATMENT_VAR] == 1].copy()
    control_df = df_encoded[df_encoded[TREATMENT_VAR] == 0].copy()
    
    # Perform matching
    distances, indices = perform_matching(treatment_df, control_df, caliper)
    matched_pairs, unmatched_treated = find_matches(distances, indices, treatment_df, control_df, caliper)
    
    # Create matched dataset
    matched_df = pd.DataFrame(matched_pairs)
    
    # Calculate ATE
    ate = calculate_ate(matched_df)
    
    # Print results
    print(f"\nMatching Statistics for {gender}:")
    print(f"Successfully matched treated units: {len(matched_pairs) // (MATCHING_RATIO + 1)}")
    print(f"Unmatched treated units: {unmatched_treated}")
    print(f"Total matched control units: {len(matched_pairs) - (len(matched_pairs) // (MATCHING_RATIO + 1))}")
    print(f"Average Treatment Effect for {gender}: {ate:.4f}")
    
    return matched_df, ate

def main():
    # Load data
    print(f"\nLoading data from {DATA_PATH}...")
    df = pd.read_csv(DATA_PATH)
    
    # Split by gender and run analysis
    male_df = df[df['gender_cd'] == 'M']
    female_df = df[df['gender_cd'] == 'F']
    
    male_matched, male_ate = run_analysis(male_df, "Male")
    female_matched, female_ate = run_analysis(female_df, "Female")
    
    return male_matched, male_ate, female_matched, female_ate

if __name__ == "__main__":
    main()












