                for _, match in selected_matches.iterrows():
                    matched_pairs.append(match)
                    used_control_indices.add(match.name)
        
        print(f"\nMatching Statistics:")
        print(f"Successfully matched treated units: {len(matched_pairs) // (matching_ratio + 1)}")
        print(f"Unmatched treated units: {len(treated_df) - len(matched_pairs) // (matching_ratio + 1)}")
        
        return matched_pairs

