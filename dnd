import pandas as pd
import numpy as np
from sklearn.linear_model import LogisticRegression
from sklearn.neighbors import NearestNeighbors
import faiss
import time
import warnings
warnings.filterwarnings('ignore')

class Timer:
    def __init__(self, description):
        self.description = description
    
    def __enter__(self):
        self.start = time.time()
        return self
    
    def __exit__(self, *args):
        self.end = time.time()
        self.duration = self.end - self.start
        print(f"{self.description}: {self.duration:.4f} seconds")

class PSMatcher:
    def __init__(self, data_path=None, x_variables=None, treatment_var=None, 
                 outcome_var=None, matching_ratio=1, n_neighbors=5, caliper_sd=0.25):
        """
        Initialize PSM matcher with configuration
        """
        self.data_path = data_path
        self.x_variables = x_variables
        self.treatment_var = treatment_var
        self.outcome_var = outcome_var
        self.matching_ratio = matching_ratio
        self.n_neighbors = n_neighbors
        self.caliper_sd = caliper_sd
    
    def get_dummy_col(self, df, features):
        """Create dummy variables for categorical features"""
        df_copy = df.copy()
        categorical_cols = []
        
        for col in features:
            if col in df_copy.columns:
                if df_copy[col].dtype == 'object' or df_copy[col].nunique() < 10:
                    categorical_cols.append(col)
                    dummies = pd.get_dummies(df_copy[col], prefix=col, drop_first=False)
                    df_copy = pd.concat([df_copy, dummies], axis=1)
                    df_copy = df_copy.drop(columns=[col])
        
        return df_copy, categorical_cols
    
    def get_propensity_score(self, data_frame, x, y):
        """Calculate propensity scores using logistic regression"""
        model = LogisticRegression(
            penalty='l2',
            C=1e6,
            solver='lbfgs',
            random_state=42,
            max_iter=1000
        )
        model.fit(data_frame[x], data_frame[y])
        ps_scores = model.predict_proba(data_frame[x])[:, 1]
        
        print("\nPropensity Score Model Coefficients:")
        coef_df = pd.DataFrame({
            'Feature': x,
            'Coefficient': model.coef_[0]})
        print(coef_df.to_string(index=False))
        
        return model, ps_scores
    
    def knn_sklearn_match(self, treated_df, control_df, caliper):
        """Perform matching using sklearn's NearestNeighbors"""
        matched_pairs = []
        used_control_indices = set()
        
        knn = NearestNeighbors(n_neighbors=self.n_neighbors)
        knn.fit(control_df[['pscore']])
        
        for idx, treated_unit in treated_df.iterrows():
            distances, indices = knn.kneighbors([[treated_unit['pscore']]])
            potential_matches = control_df.iloc[indices[0]]
            
            eligible_matches = potential_matches[
                (abs(potential_matches['pscore'] - treated_unit['pscore']) <= caliper) &
                (~potential_matches.index.isin(used_control_indices))
            ]
            
            if len(eligible_matches) >= self.matching_ratio:
                matched_pairs.append(treated_unit)
                for i in range(self.matching_ratio):
                    matched_pairs.append(eligible_matches.iloc[i])
                    used_control_indices.add(eligible_matches.index[i])
        
        return matched_pairs
    
    def knn_faiss_match(self, treated_df, control_df, caliper):
        """Perform matching using FAISS flat index"""
        matched_pairs = []
        used_control_indices = set()
        
        treated_ps = treated_df['pscore'].values.reshape(-1, 1).astype('float32')
        control_ps = control_df['pscore'].values.reshape(-1, 1).astype('float32')
        
        index = faiss.IndexFlatL2(1)
        index.add(control_ps)
        
        distances, indices = index.search(treated_ps, self.n_neighbors)
        
        for i, (dist, idx) in enumerate(zip(distances, indices)):
            matched_controls = []
            
            for j, control_idx in enumerate(idx):
                if len(matched_controls) >= self.matching_ratio:
                    break
                    
                if control_idx < 0:
                    continue
                    
                if control_idx not in used_control_indices:
                    ps_diff = abs(treated_ps[i][0] - control_ps[control_idx][0])
                    if ps_diff <= caliper:
                        matched_controls.append(control_idx)
                        used_control_indices.add(control_idx)
            
            if len(matched_controls) == self.matching_ratio:
                matched_pairs.append(treated_df.iloc[i])
                for control_idx in matched_controls:
                    matched_pairs.append(control_df.iloc[control_idx])
        
        return matched_pairs
    
    def knn_faissIVF_match(self, treated_df, control_df, caliper):
        """Perform matching using FAISS IVF index for faster matching"""
        matched_pairs = []
        used_control_indices = set()
        
        treated_ps = treated_df['pscore'].values.reshape(-1, 1).astype('float32')
        control_ps = control_df['pscore'].values.reshape(-1, 1).astype('float32')
        
        dimension = 1
        nlist = min(64, len(control_ps))
        quantizer = faiss.IndexFlatL2(dimension)
        index = faiss.IndexIVFFlat(quantizer, dimension, nlist)
        
        index.train(control_ps)
        index.add(control_ps)
        index.nprobe = min(20, nlist)
        
        distances, indices = index.search(treated_ps, self.n_neighbors)
        
        for i, (dist, idx) in enumerate(zip(distances, indices)):
            matched_controls = []
            
            for j, control_idx in enumerate(idx):
                if len(matched_controls) >= self.matching_ratio:
                    break
                    
                if control_idx < 0:
                    continue
                    
                if control_idx not in used_control_indices:
                    ps_diff = abs(treated_ps[i][0] - control_ps[control_idx][0])
                    if ps_diff <= caliper:
                        matched_controls.append(control_idx)
                        used_control_indices.add(control_idx)
            
            if len(matched_controls) == self.matching_ratio:
                matched_pairs.append(treated_df.iloc[i])
                for control_idx in matched_controls:
                    matched_pairs.append(control_df.iloc[control_idx])
        
        return matched_pairs
    
    def psm_main_function(self, match_combinations=None, matching_method='sklearn'):
        """
        Main function to perform propensity score matching
        """
        with Timer("Total PSM process"):
            # Load and prepare data
            with Timer("Data loading"):
                df = pd.read_parquet(self.data_path)
            
            with Timer("Creating dummy variables"):
                df_encoded, categorical_cols = self.get_dummy_col(df, self.x_variables)
                
                # Update features list
                features_for_model = [col for col in self.x_variables if col not in categorical_cols]
                for col in categorical_cols:
                    dummy_cols = [c for c in df_encoded.columns if c.startswith(col + '_')]
                    features_for_model.extend(dummy_cols)
            
            # Calculate propensity scores
            with Timer("Propensity score calculation"):
                model, ps = self.get_propensity_score(df_encoded, features_for_model, self.treatment_var)
                df_encoded['pscore'] = ps
                caliper = np.std(df_encoded['pscore']) * self.caliper_sd
            
            # Split into treatment and control
            with Timer("Data splitting"):
                treatment_df = df_encoded[df_encoded[self.treatment_var] == 1].copy()
                control_df = df_encoded[df_encoded[self.treatment_var] == 0].copy()
                
                print(f"\nInitial sample sizes:")
                print(f"Treatment group: {len(treatment_df)}")
                print(f"Control group: {len(control_df)}")
            
            # Select matching function
            matching_func = {
                'sklearn': self.knn_sklearn_match,
                'faiss': self.knn_faiss_match,
                'faiss_ivf': self.knn_faissIVF_match
            }[matching_method]
            
            matched_pairs = []
            
            with Timer("Matching process"):
                if match_combinations:
                    # Perform exact matching
                    for treated_cats, control_cats in match_combinations:
                        treated_mask = pd.Series(True, index=treatment_df.index)
                        control_mask = pd.Series(True, index=control_df.index)
                        
                        for cat in treated_cats:
                            treated_mask &= (treatment_df[cat] == 1)
                        for cat in control_cats:
                            control_mask &= (control_df[cat] == 1)
                        
                        treated_group = treatment_df[treated_mask]
                        control_group = control_df[control_mask]
                        
                        if len(treated_group) > 0 and len(control_group) >= self.matching_ratio:
                            curr_matches = matching_func(treated_group, control_group, caliper)
                            matched_pairs.extend(curr_matches)
                else:
                    # Perform regular PSM
                    matched_pairs = matching_func(treatment_df, control_df, caliper)
            
            with Timer("Creating final matched DataFrame"):
                if not matched_pairs:
                    print("No matches found with current settings")
                    return model, None
                
                matched_df = pd.DataFrame(matched_pairs)
                
                # Calculate and print results
                ate = matched_df[matched_df[self.treatment_var] == 1][self.outcome_var].mean() - \
                      matched_df[matched_df[self.treatment_var] == 0][self.outcome_var].mean()
                
                print(f"\nResults:")
                print(f"Matched treated units: {len(matched_pairs) // (self.matching_ratio + 1)}")
                print(f"Average Treatment Effect: {ate:.4f}")
            
            return model, matched_df

def main():
    # Example usage
    matcher = PSMatcher(
        data_path="HCA_unmatched_data_setup.parquet",
        x_variables=["age", "gender_cd", "medical_coverage_tier"],
        treatment_var="grp_binary",
        outcome_var="social_risk_score",
        matching_ratio=1,
        n_neighbors=5,
        caliper_sd=0.25
    )
    
    # Example for male to female matching using FAISS
    match_combinations = [(['gender_cd_M'], ['gender_cd_F'])]
    model, matched_data = matcher.psm_main_function(
        match_combinations=match_combinations,
        matching_method='faiss'
    )

if __name__ == "__main__":
    main()
