        'treatment_var': "treat",
        'outcome_var': "re78",
        'matching_ratio': 1,
        'n_neighbors': 5,
        'caliper_sd': 0.25
    }
    
    # Run all methods with a single propensity score calculation
    results = run_all_methods(**params)
